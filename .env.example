# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ims_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ims_user:your_secure_password_here@localhost:5432/ims_db
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0
SQLITE_PATH=./signals.db
ENV=development
SECRET_KEY=generate_a_secure_key_here

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
